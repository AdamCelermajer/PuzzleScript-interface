// This file defines the Agentic Context Description Language (ACDL) specifications 
// for the LLM calls in the PuzzleScript interactive learning agent.

PlanSubgoal[@T]: {
    U: {
        EXPLORER_INSTRUCTIONS // You are an explorer. Your goal is to find new and interesting interactions to learn from.

        env.board[@T]
        sys.known_rules[@T] // Formatted string of known rules
        
        If @T > 1 {
            RECENT_ACTIONS_HEADER
            ForEach(t: range(max(1, @T-5), @T-1)) {
                env.board[@t]
                resp.LearningAct[@t]
            }
        }

        SUBGOAL_QUESTION // Based on the known rules and recent actions, what is a good subgoal to encounter new interactions and learn new rules? (1 sentence)
    }
}

LearningAct[@T]: {
    U: {
        ACTION_INSTRUCTIONS // You are an agent in a 2D grid world. Your task is to select the single best action to take next. Output ONLY a single character for your action. No explanations.

        env.subgoal[@T] // The subgoal generated by PlanSubgoal
        env.board[@T]
        sys.known_rules[@T] // Formatted string of known rules
        
        If @T > 1 {
            RECENT_HISTORY_HEADER
            ForEach(t: range(max(1, @T-5), @T-1)) {
                resp.LearningAct[@t]
            }
        }

        ACTION_PROMPT // Analyze the board, rules, and history. Action MUST be a single character: W,A,S,D,X,R. CRITICAL: Do not repeat actions if board was unchanged.
    }
}

DeduceRules[@T]: {
    U: {
        MODELER_INSTRUCTIONS // You are a world dynamics modeler. Your task is to deduce the physics of a 2D grid world from observed events.
        STRICT_RULES // 1. GROUNDED... 2. CONCISE... 3. DIRECTION CONSISTENCY... 4. NO DUPLICATES... 5. NO CONTRADICTIONS... 6. NO OVER-GENERALISATION... Output ONLY a JSON object with key 'rules' containing a list of rule strings. Return an empty list if no new, valid rules can be confidently inferred.

        sys.known_rules[@T] // Formatted string of known rules
        env.rule_focus[@T] // Focus on deducing rules related to: <focus>
        
        If @T > 1 {
            SEQUENCE_OF_EVENTS
            ForEach(t: range(max(1, @T-5), @T-1)) {
                env.board[@t]
                resp.LearningAct[@t]
            }
        }

        DEDUCE_PROMPT // Deduce only rules that are clearly supported by the events above and do not duplicate or contradict the known rules.
    }
}

InferLegend[@T]: {
    U: {
        WORLD_ANALYST_INSTRUCTIONS // You are a world analyst. Your task is to infer the meaning of the symbols on the board from a history of world states. Provide the output as a JSON object where the key is the symbol and the value is its name (e.g., {"P": "Player", "#": "Wall"}).

        If @T > 1 {
            WORLD_HISTORY
            ForEach(t: range(max(1, @T-50), @T-1)) {
                env.board[@t]
                resp.LearningAct[@t]
            }
        }

        INFER_PROMPT // Infer the legend for this world based on the object movements and interactions you observe.
    }
}

RefineRules[@T]: {
    U: {
        ANALYST_INSTRUCTIONS // You are a world analyst. Your task is to produce a final, clean, and minimal rule set for a 2D grid world.
        REFINEMENT_STEPS // 1. DEDUPLICATE... 2. RESOLVE CONTRADICTIONS... 3. REMOVE HALLUCINATIONS... 4. DIRECTION CONSISTENCY... 5. ADD MISSING... 6. INFER LEGEND... Output a single JSON object with keys 'final_rules' (list of strings) and 'legend' (dict symbol->name).

        sys.known_rules[@T] // Formatted string of rules deduced so far
        
        If @T > 1 {
            GAMEPLAY_HISTORY
            ForEach(t: range(1, @T-1)) {
                env.board[@t]
                resp.LearningAct[@t]
            }
        }

        REFINE_PROMPT // Apply all steps above and output the cleaned JSON.
    }
}

